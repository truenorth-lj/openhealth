# ======================
# Required
# ======================
DATABASE_URL=postgresql://openhealth:openhealth@localhost:5432/openhealth
BETTER_AUTH_SECRET=generate-a-random-string-here
BETTER_AUTH_URL=http://localhost:3001

# ======================
# OAuth (optional)
# ======================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_AUTH_KEY_ID=

# ======================
# AI (optional — enables AI features)
# ======================
# Google Gemini — nutrition label OCR & AI chat
GOOGLE_AI_API_KEY=

# MiniMax — alternative AI provider for PR review
MINIMAX_API_KEY=

# ======================
# Payments (optional — enables Pro plan)
# ======================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ======================
# Web Push (optional — enables push notifications)
# Generate with: npx web-push generate-vapid-keys
# ======================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# ======================
# Observability (optional)
# ======================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_PERSONAL_API_KEY=

# ======================
# YouTube (optional — Huberman digest script)
# ======================
YOUTUBE_API_KEY=
