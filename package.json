{
  "name": "open-health",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@open-health/web",
    "dev:mobile": "turbo dev --filter=@open-health/mobile",
    "build": "turbo build --filter=@open-health/web",
    "start": "cd apps/web && npm start",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.11.0"
}
